{
  "description": "One Shot Ship plugin hooks for context persistence and notifications",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-precommand.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-iron-law-check.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-context-inject.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-session-start.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-session-end.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-session-end.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-notification.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-stop.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "tool == \"AskUserQuestion\"",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-ask-telegram.sh"
          }
        ],
        "description": "Send AskUserQuestion to Telegram for mobile notifications"
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/team-task-completed.sh"
          }
        ],
        "description": "Run tests and lint after agent task completion (team mode only)"
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/team-idle.sh"
          }
        ],
        "description": "Reassign work when a teammate agent becomes idle (team mode only)"
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-worktree-create.sh"
          }
        ],
        "description": "Initialize OSS context in new git worktrees"
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-worktree-remove.sh"
          }
        ],
        "description": "Clean up OSS state when a worktree is removed"
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-config-change.sh"
          }
        ],
        "description": "Sync OSS settings when Claude Code configuration changes"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "tool == \"AskUserQuestion\"",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-ask-telegram-answered.sh"
          }
        ],
        "description": "Report terminal answer to API (first-response-wins)"
      },
      {
        "matcher": "tool == \"Edit\" && tool_input.file_path matches \"\\\\.(ts|tsx|js|jsx)$\"",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-quality.sh"
          }
        ],
        "description": "Quality checks after JS/TS edits (console.log, format, type-check)"
      },
      {
        "matcher": "tool == \"Bash\"",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-bash-pr.sh"
          }
        ],
        "description": "PR enhancement after gh pr create"
      },
      {
        "matcher": "tool == \"Write\" || tool == \"Edit\"",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/oss-auto-format.sh"
          }
        ],
        "description": "Auto-format files after Write or Edit operations"
      }
    ]
  }
}
